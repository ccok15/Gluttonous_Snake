[node name="DetailColumns" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="LeftColumn" type="VBoxContainer" parent="MarginContainer/VBoxContainer/DetailColumns"]

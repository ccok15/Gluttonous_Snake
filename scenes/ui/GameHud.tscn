[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/game_hud.gd" id="1"]

[node name="GameHud" type="PanelContainer"]
custom_minimum_size = Vector2(680, 820)
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 18
theme_override_constants/margin_top = 18
theme_override_constants/margin_right = 18
theme_override_constants/margin_bottom = 18

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="HeaderLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "运行状态"

[node name="StatsColumns" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="LeftStats" type="VBoxContainer" parent="MarginContainer/VBoxContainer/StatsColumns"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="StageValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/LeftStats"]
layout_mode = 2
autowrap_mode = 2
text = "阶段 1"

[node name="ScoreValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/LeftStats"]
layout_mode = 2
autowrap_mode = 2
text = "分数 0 / 30"

[node name="TimeValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/LeftStats"]
layout_mode = 2
autowrap_mode = 2
text = "剩余时间 03:00.0"

[node name="LevelValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/LeftStats"]
layout_mode = 2
autowrap_mode = 2
text = "等级 1  经验 0 / 8"

[node name="LengthValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/LeftStats"]
layout_mode = 2
autowrap_mode = 2
text = "蛇身长度 4"

[node name="RightStats" type="VBoxContainer" parent="MarginContainer/VBoxContainer/StatsColumns"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="SpeedValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
layout_mode = 2
autowrap_mode = 2
text = "移动间隔 90 毫秒/步"

[node name="DashValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
layout_mode = 2
autowrap_mode = 2
text = "突进 就绪"

[node name="BeanScoreValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
layout_mode = 2
autowrap_mode = 2
text = "普通豆 +1（上次 +1）"

[node name="CriticalBeanValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
layout_mode = 2
autowrap_mode = 2
text = "暴击豆 5~10（下次 08.0 秒）"

[node name="WallPhaseValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
visible = false
layout_mode = 2
autowrap_mode = 2
text = "穿越术已激活"

[node name="ProtectionValue" type="Label" parent="MarginContainer/VBoxContainer/StatsColumns/RightStats"]
layout_mode = 2
autowrap_mode = 2
